{
  "name": "statement-manager-react",
  "version": "1.0.0",
  "description": "A simple statement manager app using React and TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "api": "json-server --watch db.json --port 5001",
    "start": "npm-run-all --parallel dev api"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "formik": "^2.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "json-server": "^0.17.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
