{
  "name": "statement-manager",
  "version": "1.0.0",
  "description": "A simple statement manager app using TypeScript and Bootstrap",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf lib/*.js lib/*.js.map lib/*.d.ts lib/*.d.ts.map",
    "api": "json-server --watch db.json --port 5001",
    "dev": "npm-run-all --parallel watch api"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "json-server": "^0.17.4",
    "npm-run-all": "^4.1.5"
  }
}
